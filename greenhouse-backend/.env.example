# ==================== SERVER ====================
PORT=3000
NODE_ENV=production

# ==================== MONGODB ====================
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.mongodb.net/greenhouse?retryWrites=true&w=majority

# ==================== JWT ====================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too
JWT_REFRESH_EXPIRE=30d

# ==================== RASPBERRY PI API ====================
# This key is shared between the Raspberry Pi and backend
RASPI_API_KEY=your_raspi_api_key_here_change_this

# ==================== CLIENT URL ====================
# For CORS - in production, set to your Render URL
CLIENT_URL=https://your-greenhouse-app.onrender.com

# ==================== WEBCAM STREAM ====================
# Raspberry Pi's Cloudflare tunnel or local URL for webcam
WEBCAM_URL=https://webcam.yourdomain.com

# ==================== EMAIL (for forgot password) ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Greenhouse System <your_email@gmail.com>
