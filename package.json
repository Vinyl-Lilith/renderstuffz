{
  "name": "biocube",
  "version": "1.0.0",
  "private": true,
  "description": "BioCube Smart Greenhouse Management System",
  "scripts": {
    "install:all": "npm install && cd frontend && npm install",
    "build": "cd frontend && npm run build",
    "start": "node backend/server.js",
    "dev": "concurrently \"nodemon backend/server.js\" \"cd frontend && npm run dev\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": { "node": ">=18.0.0" }
}
